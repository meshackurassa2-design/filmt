default_platform(:ios)

platform :ios do
  desc "Build an unsigned IPA for Sideloading (AltStore/Sideloadly)"
  lane :build_unsigned do
    # 1. Clean and Build the .app directly using xcodebuild
    Dir.chdir("ios/App") do
      sh("xcodebuild -workspace App.xcworkspace -scheme App -configuration Release -sdk iphoneos -archivePath ./build/App.xcarchive archive CODE_SIGNING_ALLOWED=NO CODE_SIGN_REQUIRED=NO CODE_SIGN_IDENTITY='' PROVISIONING_PROFILE_SPECIFIER=''")

      # 2. Export the .app from the archive
      sh("xcodebuild -exportArchive -archivePath ./build/App.xcarchive -exportPath ./build/Export -exportOptionsPlist ExportOptions.plist CODE_SIGNING_ALLOWED=NO CODE_SIGN_IDENTITY=''")

      # 3. Create the Payload directory structure for a valid IPA
      sh("rm -rf Payload")
      sh("mkdir Payload")
      sh("cp -R ./build/Export/App.app ./Payload/")

      # 4. Zip the Payload into a .ipa
      sh("zip -r ../../FilamuTimes_Sideload.ipa Payload")
    end
  end
end
